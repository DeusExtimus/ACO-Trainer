<Window x:Class="ACOverlay.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AC Map"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#DD0A0A14"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="150" Height="170"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#CC0A0A0F" CornerRadius="8,8,0,0"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock x:Name="TxtCombo" Text="TRACK MAP" Foreground="#334455"
                           FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,6,0">
                    <TextBlock x:Name="StatusDot" Text="●" FontSize="9"
                               Foreground="#FF4444" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="×" Click="CloseButton_Click"
                            Background="Transparent" Foreground="#555"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Width="18" Height="18" Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Map canvas -->
        <Border Grid.Row="1" Background="#CC0A0A0F" ClipToBounds="True">
            <Canvas x:Name="TrackCanvas" ClipToBounds="True"/>
        </Border>

        <!-- Info bar -->
        <Border Grid.Row="2" Background="#CC0A0A0F"
                BorderBrush="#1A2A3A" BorderThickness="0,1,0,0"
                CornerRadius="0,0,8,8">
            <Grid Margin="10,4,10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="L" Foreground="#334" FontFamily="Consolas" FontSize="8" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtLap" Text="—" Foreground="#FFD700"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="3,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtTime" Text="—:——"
                           Foreground="#00BFFF" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="TxtBest" Text=""
                           Foreground="#FFD70099" FontFamily="Consolas" FontSize="8"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
